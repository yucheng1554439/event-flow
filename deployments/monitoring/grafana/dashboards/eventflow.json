{
  "title": "EventFlow Platform",
  "uid": "eventflow-main",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "title": "Events Processed / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [{ "expr": "rate(events_processed_total[5m])", "legendFormat": "{{topic}}/{{consumer_group}}" }]
    },
    {
      "title": "Events Failed",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [{ "expr": "rate(events_failed_total[5m])", "legendFormat": "{{topic}}/{{reason}}" }]
    },
    {
      "title": "Consumer Lag",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [{ "expr": "consumer_lag", "legendFormat": "{{topic}} p{{partition}}" }]
    },
    {
      "title": "Queue Depth",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "targets": [{ "expr": "queue_depth", "legendFormat": "{{topic}}" }]
    },
    {
      "title": "Retry Attempts",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [{ "expr": "rate(retry_attempts_total[5m])", "legendFormat": "{{topic}}/{{status}}" }]
    },
    {
      "title": "Workflow Duration (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [{ "expr": "histogram_quantile(0.95, rate(workflow_duration_seconds_bucket[5m]))", "legendFormat": "{{workflow_name}}" }]
    }
  ]
}
