FROM golang:1.22-alpine AS builder
RUN apk add --no-cache gcc musl-dev librdkafka-dev
WORKDIR /app
COPY go.mod ./
RUN go mod download
COPY . .
# Link against Alpine's musl librdkafka — default build uses vendored glibc .a and fails on musl.
RUN CGO_ENABLED=1 go build -tags dynamic -o /api-gateway ./cmd/api-gateway

FROM alpine:3.19
RUN apk add --no-cache ca-certificates librdkafka
COPY --from=builder /api-gateway /usr/local/bin/api-gateway
EXPOSE 8080 9090
ENTRYPOINT ["api-gateway"]
